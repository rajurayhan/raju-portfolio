---
interface Props {
  num: string;
  title: string;
  meta?: string;
}
const { num, title, meta } = Astro.props;
---

<div class="section-head">
  <span class="num">§ {num}</span>
  <span class="title">{title}</span>
  <span class="rest" />
  {meta && <span style="font-size: 11px; color: var(--muted); white-space: nowrap">{meta}</span>}
</div>
