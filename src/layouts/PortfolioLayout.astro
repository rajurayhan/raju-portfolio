---
import '../styles/portfolio.css';

interface Props {
  title?: string;
  description?: string;
  navCurrent?: 'home' | 'work' | 'sulus' | 'about' | 'contact';
}

const { title = 'Raju Rayhan — Portfolio', description = 'Platform architect, AI voice & automation.', navCurrent = 'home' } = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <script is:inline>
      (function (g) {
        // Single source; reused on bfcache restore (body `pageshow`) so all routes stay in sync.
        g.__rajuApplyTheme = function () {
          try {
            var s = localStorage.getItem('raju-theme');
            var t =
              s === 'light' || s === 'dark'
                ? s
                : g.matchMedia('(prefers-color-scheme: dark)').matches
                  ? 'dark'
                  : 'light';
            g.document.documentElement.setAttribute('data-theme', t);
            return t;
          } catch (e) {
            g.document.documentElement.setAttribute('data-theme', 'light');
            return 'light';
          }
        };
        g.__rajuApplyTheme();
      })(window);
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <style is:global>
      #site-root {
        min-height: 100vh;
        --mono: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
      }
    </style>
  </head>
  <body>
    <div id="site-root" class:list={['page', 'density-regular']}>
      <slot />
    </div>
    <script is:inline>
      (function () {
        window.addEventListener('pageshow', function (e) {
          if (e.persisted && window.__rajuApplyTheme) window.__rajuApplyTheme();
        });
        document.addEventListener('keydown', function (e) {
          if (e.defaultPrevented) return;
          if (e.metaKey || e.ctrlKey || e.altKey) return;
          var t = e.target;
          if (t && (t instanceof HTMLInputElement || t instanceof HTMLTextAreaElement || t instanceof HTMLSelectElement)) return;
          if (e.key === 'k' || e.key === 'K') {
            e.preventDefault();
            if (location.pathname !== '/work') location.href = '/work';
          }
        });
      })();
    </script>
  </body>
</html>
