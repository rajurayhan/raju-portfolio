# Resend (https://resend.com) — required for /api/contact
RESEND_API_KEY=re_xxxx

# Receives form submissions; defaults to send2raju.bd@gmail.com if unset
CONTACT_TO_EMAIL=send2raju.bd@gmail.com

# Must be a verified sender/domain in Resend. Resend’s sandbox uses onboarding@resend.dev
CONTACT_FROM_EMAIL=Portfolio <onboarding@resend.dev>
